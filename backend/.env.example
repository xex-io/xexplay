# Server
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=debug

# Database (XEX Play's own DB — separate from Exchange)
DATABASE_URL=postgres://xexplay:xexplay@localhost:5432/xexplay?sslmode=disable

# Redis (XEX Play's own instance)
REDIS_URL=redis://localhost:6379

# Auth (shared JWT secret — same value as XEX Exchange)
JWT_SECRET=your-shared-jwt-secret-minimum-32-characters-long

# CORS (admin panel origin)
CORS_ORIGINS=http://localhost:3000
